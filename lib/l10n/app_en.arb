  "guestDemoAdventurous1Name": "Ridge Sunrise Hike",
  "guestDemoAdventurous1Meta": "06:00 • Free",
  "guestDemoAdventurous1Desc": "Steep trail, wide views, early start.",
  "guestDemoAdventurous2Name": "Quayside Lunch Deck",
