  "guestDemoRomantic1Name": "Courtyard Café",
  "guestDemoRomantic1Meta": "10:00 • €€",
  "guestDemoRomantic1Desc": "Quiet corners and shared pastries.",
  "guestDemoRomantic2Name": "Independent Bookshop Browse",
